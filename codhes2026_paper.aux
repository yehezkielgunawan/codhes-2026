\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Token-to-Word Ratio comparison across platforms. Human documentation (pink) generally requires fewer tokens per word than machine documentation (gold), except for FastAPI, whose verbose HTML inflates the ratio. React and LangChain show extreme machine-to-word ratios due to their link-dense content.}}{8}{figure.caption.5}\protected@file@percent }
\newlabel{fig:token}{{3}{8}{Token-to-Word Ratio comparison across platforms. Human documentation (pink) generally requires fewer tokens per word than machine documentation (gold), except for FastAPI, whose verbose HTML inflates the ratio. React and LangChain show extreme machine-to-word ratios due to their link-dense content}{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Cohen's d effect sizes for all metrics and evaluation dimensions. Negative values (red) indicate machine documentation scores higher; positive values (blue) indicate human documentation scores higher. Vertical dashed lines denote conventional small, medium, and large effect thresholds. All LLM evaluation dimensions show large effects favoring machine documentation, while only Flesch Reading Ease shows a medium effect favoring human documentation.}}{9}{figure.caption.7}\protected@file@percent }
\newlabel{fig:effect}{{4}{9}{Cohen's d effect sizes for all metrics and evaluation dimensions. Negative values (red) indicate machine documentation scores higher; positive values (blue) indicate human documentation scores higher. Vertical dashed lines denote conventional small, medium, and large effect thresholds. All LLM evaluation dimensions show large effects favoring machine documentation, while only Flesch Reading Ease shows a medium effect favoring human documentation}{figure.caption.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces Platform-by-Platform LRI Comparison}}{9}{table.caption.8}\protected@file@percent }
\newlabel{tab:platform-lri}{{IV}{9}{Platform-by-Platform LRI Comparison}{table.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Boxplot distribution of LRI differences (Machine $-$ Human) across the ten platforms. The median improvement is approximately 17 points. The Vercel outlier ($-12$) is the only platform favoring human documentation. Individual points are labeled by platform name.}}{10}{figure.caption.9}\protected@file@percent }
\newlabel{fig:lri-box}{{5}{10}{Boxplot distribution of LRI differences (Machine $-$ Human) across the ten platforms. The median improvement is approximately 17 points. The Vercel outlier ($-12$) is the only platform favoring human documentation. Individual points are labeled by platform name}{figure.caption.9}{}}
