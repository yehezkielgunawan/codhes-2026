{
	"name": "readibility-demo",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "$npm_execpath run build && vite preview",
		"deploy": "$npm_execpath run build && wrangler deploy",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint ."
	},
	"dependencies": {
		"cheerio": "^1.2.0",
		"hono": "^4.12.23",
		"js-tiktoken": "^1.0.21",
		"text-readability": "^1.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@cloudflare/vite-plugin": "^1.2.3",
		"@tailwindcss/vite": "^4.3.0",
		"tailwindcss": "^4.0.0",
		"vite": "^6.3.5",
		"vite-ssr-components": "^0.6.1",
		"vitest": "^3.0.0",
		"wrangler": "^4.17.0"
	}
}
